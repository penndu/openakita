    "org_815eec957c81": {
      "id": "org_815eec957c81",
      "name": "v25_spec_e4_e50d09f1",
      "template_id": "content_ops",
      "description": "Seven-node editorial team led by an editor-in-chief: a planning editor owns two writers and a visual designer; an SEO specialist and a data analyst close the loop with data-driven topic suggestions. Mirrors the legacy content-ops template in the v2 schema.",
      "nodes": [
        {
          "id": "node_5378574e9687",
          "org_id": "org_815eec957c81",
          "type": "llm",
          "role": "editor_in_chief",
          "label": "主编",
          "persona_prompt": "你是【主编】节点。直属下级：planner（策划编辑）、seo_opt（SEO）、\ndata_analyst（数据分析）。工作流：\n1) 把出品人的内容方向拆成选题 / 排期任务派给 planner；\n2) 让 seo_opt 全程关注关键词与流量目标，让 data_analyst 把读者数据\n   反馈给 planner 形成迭代闭环；\n3) deliverable 给出品人：本期内容总览、流量数据、下期建议。\n",
          "tool_subset": [
            "research",
            "planning",
            "memory"
          ],
          "workbench": null,
          "runtime_overrides": {
            "max_iterations": null,
            "max_turns": null,
            "max_stalls": null,
            "suspect_secs": null,
            "persona_overlay": null
          },
          "parent_id": null,
          "status": "created",
          "last_seen": null,
          "last_progress_at": null,
          "created_at": "2026-05-28T09:56:25.677499+00:00"
        },
        {
          "id": "node_1c6457e19bf7",
          "org_id": "org_815eec957c81",
          "type": "llm",
          "role": "content_planner",
          "label": "策划编辑",
          "persona_prompt": "你是【策划编辑】节点。直属下级：writer_a / writer_b / visual。\n工作流：\n1) 根据主编的方向 + data_analyst 的数据线索，输出本期选题清单与排期；\n2) 把每个选题派给 writer_a 或 writer_b，并让 visual 负责配图/封面；\n3) deliverable 列出：选题 → 文案 → 配图 → 发布时间的对照表。\n",
          "tool_subset": [
            "research",
            "planning",
            "memory"
          ],
          "workbench": null,
          "runtime_overrides": {
            "max_iterations": null,
            "max_turns": null,
            "max_stalls": null,
            "suspect_secs": null,
            "persona_overlay": null
          },
          "parent_id": "node_5378574e9687",
          "status": "created",
          "last_seen": null,
          "last_progress_at": null,
          "created_at": "2026-05-28T09:56:25.677499+00:00"
        },
        {
          "id": "node_e4bf8717ae0b",
          "org_id": "org_815eec957c81",
          "type": "llm",
          "role": "writer",
          "label": "文案写手A",
          "persona_prompt": "你是【文案写手 A】节点，擅长深度长文。按 planner 派单产出文章：\nresearch → 大纲 → 正文 → 自检。deliverable 列出：标题、字数、引用来源、\n亮点段落。与 seo_opt collaborate 优化关键词，与 visual collaborate 提供\n配图说明。\n",
          "tool_subset": [
            "research",
            "filesystem",
            "memory"
          ],
          "workbench": null,
          "runtime_overrides": {
            "max_iterations": null,
            "max_turns": null,
            "max_stalls": null,
            "suspect_secs": null,
            "persona_overlay": null
          },
          "parent_id": "node_1c6457e19bf7",
          "status": "created",
          "last_seen": null,
          "last_progress_at": null,
          "created_at": "2026-05-28T09:56:25.677499+00:00"
        },
        {
          "id": "node_94caddbdea09",
          "org_id": "org_815eec957c81",
          "type": "llm",
          "role": "writer",
          "label": "文案写手B",
          "persona_prompt": "你是【文案写手 B】节点，擅长短文与社媒文案。按 planner 派单产出短稿：\n角度 → 钩子 → 正文 → CTA。deliverable 列出：标题、平台、字数、转化点。\n与 seo_opt 协调关键词，与 visual 协调配图。\n",
          "tool_subset": [
            "research",
            "filesystem",
            "memory"
          ],
          "workbench": null,
          "runtime_overrides": {
