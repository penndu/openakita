{
  "id": "omni-post",
  "name": "Omni Post",
  "version": "0.1.0",
  "type": "python",
  "entry": "plugin.py",
  "description": "Cross-platform publishing studio: one asset, N platforms x M accounts, Playwright + MultiPost-Extension dual engines, Asset Bus handoff, MDRM publish memory.",
  "display_name_zh": "\u5168\u5a92\u53d1\u5e03",
  "display_name_en": "Omni Post",
  "description_i18n": {
    "zh": "\u5168\u5a92\u53d1\u5e03\uff1a\u4e00\u4efd\u7d20\u6750\u540c\u6b65\u53d1\u5f80 10+ \u81ea\u5a92\u4f53\u5e73\u53f0\u3001N \u4e2a\u8d26\u53f7\uff1b\u53cc\u5f15\u64ce\uff08Playwright \u81ea\u7814 + MultiPost \u6269\u5c55\u517c\u5bb9\uff09+ \u5bbf\u4e3b Asset Bus + MDRM \u53d1\u5e03\u8bb0\u5fc6\u3002",
    "en": "Cross-platform publishing: one asset, N platforms x M accounts. Playwright + MultiPost dual engines, Asset Bus handoff, MDRM publish memory."
  },
  "author": "OpenAkita",
  "category": "creative",
  "tags": ["publish", "cross-platform", "playwright", "automation", "social-media"],
  "permissions": [
    "tools.register",
    "routes.register",
    "hooks.basic",
    "config.read",
    "config.write",
    "data.own",
    "assets.publish",
    "assets.consume",
    "memory.read",
    "memory.write",
    "brain.access",
    "vector.access"
  ],
  "requires": {
    "openakita": ">=1.27.0",
    "plugin_api": "~1",
    "plugin_ui_api": "~1",
    "sdk": ">=0.7.0,<0.8.0"
  },
  "provides": {
    "tools": [
      "omni_post_publish",
      "omni_post_schedule",
      "omni_post_cancel",
      "omni_post_retry",
      "omni_post_list_tasks",
      "omni_post_get_task",
      "omni_post_list_accounts",
      "omni_post_add_account",
      "omni_post_remove_account",
      "omni_post_refresh_account",
      "omni_post_list_assets",
      "omni_post_delete_asset",
      "omni_post_pull_from_asset_bus",
      "omni_post_export_report"
    ],
    "routes": true,
    "skill": "SKILL.md"
  },
  "ui": {
    "entry": "ui/dist/index.html",
    "icon": "send",
    "title": "\u5168\u5a92\u53d1\u5e03",
    "title_i18n": {
      "zh": "\u5168\u5a92\u53d1\u5e03",
      "en": "Omni Post"
    },
    "sidebar_group": "apps",
    "permissions": ["upload", "download", "notifications", "theme", "clipboard"]
  },
  "load_timeout": 20
}
