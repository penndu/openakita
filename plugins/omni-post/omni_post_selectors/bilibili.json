{
  "platform": "bilibili",
  "version": "1.0.0",
  "notes": "Bilibili 'member' upload flow. Titles cap at 80 chars; the adapter truncates, it does not refuse.",
  "actions": {
    "precheck": {
      "url": "https://member.bilibili.com/platform/upload/video/frame",
      "timeout_ms": 30000,
      "steps": [
        {
          "kind": "wait",
          "selector": "input[type=file]",
          "timeout_ms": 25000
        },
        {
          "kind": "assert_url",
          "pattern": "member\\.bilibili\\.com",
          "on_fail": "cookie_expired"
        }
      ]
    },
    "fill_form": {
      "url": "https://member.bilibili.com/platform/upload/video/frame",
      "timeout_ms": 60000,
      "steps": [
        {
          "kind": "upload",
          "selector": "input[type=file]",
          "field": "asset_storage_path",
          "timeout_ms": 30000
        },
        {
          "kind": "wait",
          "selector": "input[placeholder*='标题']",
          "timeout_ms": 60000
        },
        {
          "kind": "type",
          "selector": "input[placeholder*='标题']",
          "text": "{{title}}",
          "clear": true
        },
        {
          "kind": "type",
          "selector": "div[class*='description'] [contenteditable=true]",
          "text": "{{description}}\n\nTags: {{tags}}",
          "clear": true
        }
      ]
    },
    "submit": {
      "timeout_ms": 60000,
      "capture_url_on_success": true,
      "steps": [
        {
          "kind": "click",
          "selector": "button:has-text('立即投稿')",
          "timeout_ms": 15000
        },
        {
          "kind": "wait",
          "selector": "div:has-text('投稿成功'), div:has-text('审核中')",
          "timeout_ms": 60000
        }
      ]
    },
    "probe": {
      "url": "https://member.bilibili.com/platform/upload/video/frame",
      "timeout_ms": 15000,
      "steps": [
        {
          "kind": "wait",
          "selector": "input[type=file]",
          "timeout_ms": 12000
        }
      ]
    }
  }
}
