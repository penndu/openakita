{
  "platform": "douyin",
  "version": "1.0.0",
  "notes": "Douyin creator upload flow. Creator URL verified 2026-04; revisit selectors monthly via the self-heal probe.",
  "actions": {
    "precheck": {
      "url": "https://creator.douyin.com/creator-micro/content/upload",
      "timeout_ms": 30000,
      "steps": [
        {
          "kind": "wait",
          "selector": "input[type=file]",
          "timeout_ms": 25000
        },
        {
          "kind": "assert_url",
          "pattern": "creator\\.douyin\\.com",
          "on_fail": "cookie_expired"
        }
      ]
    },
    "fill_form": {
      "url": "https://creator.douyin.com/creator-micro/content/upload",
      "timeout_ms": 60000,
      "steps": [
        {
          "kind": "upload",
          "selector": "input[type=file]",
          "field": "asset_storage_path",
          "timeout_ms": 30000
        },
        {
          "kind": "wait",
          "selector": "div[class*='caption']",
          "timeout_ms": 60000
        },
        {
          "kind": "type",
          "selector": "div[class*='caption'] [contenteditable=true]",
          "text": "{{title}}\n{{description}}\n{{tags}}",
          "clear": true,
          "timeout_ms": 15000
        },
        {
          "kind": "wait",
          "selector": "button:has-text('发布'), button:has-text('Publish')",
          "optional": true,
          "timeout_ms": 5000
        }
      ]
    },
    "submit": {
      "timeout_ms": 60000,
      "capture_url_on_success": true,
      "steps": [
        {
          "kind": "click",
          "selector": "button:has-text('发布'), button:has-text('Publish')",
          "timeout_ms": 15000
        },
        {
          "kind": "wait",
          "selector": "div:has-text('发布成功'), div:has-text('已发布')",
          "timeout_ms": 60000
        }
      ]
    },
    "probe": {
      "url": "https://creator.douyin.com/creator-micro/content/upload",
      "timeout_ms": 15000,
      "steps": [
        {
          "kind": "wait",
          "selector": "input[type=file]",
          "timeout_ms": 12000
        }
      ]
    }
  }
}
