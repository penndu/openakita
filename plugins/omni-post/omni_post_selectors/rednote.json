{
  "platform": "rednote",
  "version": "1.0.0",
  "notes": "Xiaohongshu (RedNote) creator. The 'upload' tab is keyed off text because the class names are obfuscated.",
  "actions": {
    "precheck": {
      "url": "https://creator.xiaohongshu.com/publish/publish?source=official",
      "timeout_ms": 30000,
      "steps": [
        {
          "kind": "wait",
          "selector": "div:has-text('上传视频'), div:has-text('上传图文')",
          "timeout_ms": 25000
        },
        {
          "kind": "assert_url",
          "pattern": "creator\\.xiaohongshu\\.com",
          "on_fail": "cookie_expired"
        }
      ]
    },
    "fill_form": {
      "url": "https://creator.xiaohongshu.com/publish/publish?source=official",
      "timeout_ms": 60000,
      "steps": [
        {
          "kind": "upload",
          "selector": "input[type=file]",
          "field": "asset_storage_path",
          "timeout_ms": 30000
        },
        {
          "kind": "wait",
          "selector": "input[placeholder*='标题'], input[placeholder*='title']",
          "timeout_ms": 60000
        },
        {
          "kind": "type",
          "selector": "input[placeholder*='标题'], input[placeholder*='title']",
          "text": "{{title}}",
          "clear": true
        },
        {
          "kind": "type",
          "selector": "div[contenteditable=true]",
          "text": "{{description}}\n{{tags}}",
          "clear": true
        }
      ]
    },
    "submit": {
      "timeout_ms": 60000,
      "capture_url_on_success": true,
      "steps": [
        {
          "kind": "click",
          "selector": "button:has-text('发布')",
          "timeout_ms": 15000
        },
        {
          "kind": "wait",
          "selector": "div:has-text('发布成功')",
          "timeout_ms": 60000
        }
      ]
    },
    "probe": {
      "url": "https://creator.xiaohongshu.com/publish/publish?source=official",
      "timeout_ms": 15000,
      "steps": [
        {
          "kind": "wait",
          "selector": "div:has-text('上传视频'), div:has-text('上传图文')",
          "timeout_ms": 12000
        }
      ]
    }
  }
}
