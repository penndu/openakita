{
  "id": "clip-sense",
  "name": "ClipSense Video Editor",
  "version": "1.0.0",
  "description": "AI-powered video editing — highlight extraction, silence removal, topic splitting, talking-head polish",
  "display_name_zh": "智剪工坊",
  "display_name_en": "ClipSense Video Editor",
  "description_i18n": {
    "zh": "AI 智能视频剪辑 — 高光提取 / 静音精剪 / 段落拆条 / 口播精编",
    "en": "AI-powered video editing — highlight extraction, silence removal, topic splitting, talking-head polish"
  },
  "type": "python",
  "entry": "plugin.py",
  "author": "OpenAkita",
  "category": "creative",
  "tags": ["video", "editing", "ai", "dashscope", "ffmpeg"],
  "permissions": [
    "tools.register",
    "routes.register",
    "hooks.basic",
    "config.read",
    "config.write",
    "data.own",
    "brain.access"
  ],
  "requires": {
    "openakita": ">=1.27.0",
    "plugin_api": "~2",
    "plugin_ui_api": "~1",
    "sdk": ">=0.7.0,<0.8.0"
  },
  "provides": {
    "tools": [
      "clip_sense_create",
      "clip_sense_status",
      "clip_sense_list",
      "clip_sense_cancel"
    ],
    "routes": true
  },
  "ui": {
    "entry": "ui/dist/index.html",
    "title": "智剪工坊",
    "title_i18n": {
      "zh": "智剪工坊",
      "en": "ClipSense"
    },
    "sidebar_group": "apps",
    "permissions": ["upload", "download", "notifications", "theme", "clipboard"]
  }
}
