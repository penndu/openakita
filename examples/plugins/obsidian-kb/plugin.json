{
  "id": "obsidian-kb",
  "name": "Obsidian 知识库",
  "version": "1.1.0",
  "description": "将 Obsidian Vault 接入 OpenAkita 作为 RAG 知识源，支持全文搜索、标签过滤、Vault 概览",
  "author": "OpenAkita Team",
  "license": "MIT",
  "type": "python",
  "entry": "plugin.py",
  "permissions": ["tools.register", "hooks.retrieve", "retrieval.register", "config.read", "config.write", "log"],
  "provides": {
    "tools": ["obsidian_search", "obsidian_vault_info"],
    "retrieval_sources": ["obsidian"],
    "hooks": ["on_retrieve"]
  },
  "category": "knowledge",
  "tags": ["rag", "obsidian", "knowledge-base", "markdown"]
}
